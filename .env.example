# ===========================================
# Notion Web - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# ----- Database -----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/notion_clone"

# ----- Auth -----
NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ----- App URL -----
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----- Real-time Collaboration -----
# Requires running: pnpm collab
# NEXT_PUBLIC_COLLAB_URL=ws://localhost:4000
# COLLAB_PORT=4000
# WebRTC voice room config
# WEBRTC_STUN_URLS=stun:stun.l.google.com:19302
# WEBRTC_TURN_URLS=turn:turn.example.com:3478
# WEBRTC_TURN_USERNAME=your-turn-username
# WEBRTC_TURN_CREDENTIAL=your-turn-password
# Rollout flags
# COLLAB_CHANNELS_ENABLED=true
# COLLAB_VOICE_ENABLED=true
# COLLAB_SCREEN_SHARE_ENABLED=true
# COLLAB_COBROWSE_ENABLED=true

# ----- OpenAI (AI assistant) -----
OPENAI_API_KEY=sk-your-openai-key
# Meeting notes model / cadence
# MEETING_NOTES_MODEL=gpt-5.4-mini
# MEETING_NOTES_DEBOUNCE_MS=30000
# MEETING_TRANSCRIPTION_LANGUAGE=ko
# MEETING_TRANSCRIPTION_GLOSSARY=Yestion,Notion Web,회의록
# MEETING_TRANSCRIPTION_REPLACEMENTS=예션=>Yestion,노션 웹=>Notion Web

# ----- Email (SMTP) -----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Notion Web <your-email@gmail.com>"

# ----- Integrations (optional) -----
# Slack
# SLACK_CLIENT_ID=your-slack-client-id
# SLACK_CLIENT_SECRET=your-slack-client-secret
# SLACK_SIGNING_SECRET=your-slack-signing-secret

# GitHub
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# Google Calendar
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Resend (email integration)
# RESEND_API_KEY=re_your-resend-api-key
# RESEND_FROM_EMAIL=noreply@example.com

# Unsplash (cover images)
# NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Integration encryption key (for storing OAuth tokens)
# INTEGRATION_SECRET_KEY=your-32-char-hex-secret

# Internal scheduler endpoint secret (required for scheduled workflows/automations)
# SCHEDULER_SECRET=your-long-random-secret

# ----- MCP Server (optional) -----
# NOTION_CLONE_API_URL=http://localhost:3000
# NOTION_CLONE_API_KEY=your-api-key
