generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  password       String
  avatarUrl      String?
  locale         String    @default("ko")
  theme          String    @default("system")
  emailVerified  Boolean   @default(false)
  verifyToken    String?
  verifyTokenExp DateTime?
  resetToken     String?
  resetTokenExp  DateTime?
  emailNotify    Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  memberships          WorkspaceMember[]
  sessions             Session[]
  favorites            Favorite[]
  pagePermissions      PagePermission[]
  comments             Comment[]
  notifications        Notification[]
  activityLogs         ActivityLog[]
  chatMessages         ChatMessage[]
  workspaceChannelMessages WorkspaceChannelMessage[]
  workspaceChannelVoicePresences WorkspaceChannelVoicePresence[]
  workspaceChannelReadStates WorkspaceChannelReadState[]
  workspaceChannelAuditLogs WorkspaceChannelAuditLog[]
  commentReactions     CommentReaction[]
  teamspaceMemberships TeamspaceMember[]
  templates            Template[]
  integrations         Integration[]      @relation("IntegrationCreator")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      WorkspaceMember[]
  pages        Page[]
  teamspaces   Teamspace[]
  apiKeys      ApiKey[]
  customRoles  CustomRole[]
  integrations Integration[]
  webhooks     Webhook[]
  templates    Template[]
  meetingSessions MeetingSession[]
  channels     WorkspaceChannel[]
  channelAuditLogs WorkspaceChannelAuditLog[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        Role     @default(MEMBER)
  customRoleId String?
  joinedAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customRole CustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@index([customRoleId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Teamspace {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  icon        String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   TeamspaceMember[]
  pages     Page[]
  channels  WorkspaceChannel[]

  @@index([workspaceId])
}

model TeamspaceMember {
  id          String   @id @default(cuid())
  teamspaceId String
  userId      String
  role        String   @default("member") // "owner" | "member"
  joinedAt    DateTime @default(now())

  teamspace Teamspace @relation(fields: [teamspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamspaceId, userId])
  @@index([userId])
}

model Page {
  id           String    @id @default(cuid())
  workspaceId  String
  parentId     String?
  teamspaceId  String?
  title        String    @default("")
  icon         String?
  cover        String?
  isTemplate   Boolean   @default(false)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  isLocked     Boolean   @default(false)
  isFullWidth  Boolean   @default(false)
  meetingEnabled Boolean @default(false)
  position     Int       @default(0)
  createdBy    String
  lastEditedBy String
  yjsState     Bytes?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent            Page?            @relation("PageTree", fields: [parentId], references: [id], onDelete: SetNull)
  children          Page[]           @relation("PageTree")
  teamspace         Teamspace?       @relation(fields: [teamspaceId], references: [id], onDelete: SetNull)
  favorites         Favorite[]
  blocks            Block[]
  database          Database?
  row               Row?
  permissions       PagePermission[]
  comments          Comment[]
  activityLogs      ActivityLog[]
  chatMessages      ChatMessage[]
  publicAccessToken String?          @unique
  publicAccessLevel String?
  snapshots         PageSnapshot[]
  syncedBlocks      SyncedBlock[]
  meetingSessions   MeetingSession[]

  @@index([workspaceId])
  @@index([parentId])
  @@index([isDeleted])
  @@index([teamspaceId])
}

model PageSnapshot {
  id        String   @id @default(cuid())
  pageId    String
  blocks    Json     @default("[]")
  title     String   @default("")
  createdBy String
  createdAt DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([pageId, createdAt])
}

model Block {
  id        String   @id @default(cuid())
  pageId    String
  parentId  String?
  type      String
  content   Json     @default("{}")
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  page     Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  parent   Block?  @relation("BlockTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Block[] @relation("BlockTree")

  @@index([pageId])
  @@index([parentId])
  @@index([pageId, position])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  pageId    String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([userId, pageId])
  @@index([userId])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

model Database {
  id        String    @id @default(cuid())
  pageId    String    @unique
  isInline  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isLocked  Boolean   @default(false)
  lockedBy  String?
  lockedAt  DateTime?

  page         Page           @relation(fields: [pageId], references: [id], onDelete: Cascade)
  properties   Property[]
  views        DatabaseView[]
  rows         Row[]
  rowTemplates RowTemplate[]

  @@index([pageId])
}

model Property {
  id         String  @id @default(cuid())
  databaseId String
  name       String
  type       String
  config     Json    @default("{}")
  position   Int     @default(0)
  isVisible  Boolean @default(true)

  database Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId])
  @@index([databaseId, position])
}

model DatabaseView {
  id         String @id @default(cuid())
  databaseId String
  name       String
  type       String
  config     Json   @default("{}")
  position   Int    @default(0)

  database Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId])
}

model Row {
  id         String   @id @default(cuid())
  databaseId String
  pageId     String   @unique
  values     Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  database Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  page     Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([databaseId])
  @@index([databaseId, createdAt])
  @@index([pageId])
}

model RowTemplate {
  id         String   @id @default(cuid())
  databaseId String
  name       String
  icon       String?
  values     Json     @default("{}")
  position   Int      @default(0)
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  database Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId])
}

model PagePermission {
  id        String   @id @default(cuid())
  pageId    String
  userId    String
  level     String   @default("view") // "edit" | "comment" | "view"
  createdAt DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pageId, userId])
  @@index([pageId])
  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  pageId    String
  blockId   String?
  parentId  String?
  content   String
  authorId  String
  resolved  Boolean  @default(false)
  reactions Json     @default("{}")
  textFrom  Int?
  textTo    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  page          Page              @relation(fields: [pageId], references: [id], onDelete: Cascade)
  author        User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent        Comment?          @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]         @relation("CommentThread")
  reactions_rel CommentReaction[]

  @@index([pageId])
  @@index([pageId, createdAt])
  @@index([blockId])
  @@index([parentId])
}

model CommentReaction {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@index([commentId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String?
  pageId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@index([userId, createdAt])
}

model ApiKey {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  key         String   @unique
  createdBy   String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([workspaceId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  pageId    String
  userId    String
  action    String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([userId])
  @@index([pageId, createdAt])
}

model SyncedBlock {
  id            String   @id @default(cuid())
  sourceBlockId String
  sourcePageId  String
  content       Json     @default("{}")
  version       Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sourcePage Page @relation(fields: [sourcePageId], references: [id], onDelete: Cascade)

  @@index([sourceBlockId])
  @@index([sourcePageId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  pageId    String
  userId    String
  content   String
  type      String   @default("text") // "text" | "block_ref" | "system" | "poll" | "task"
  metadata  Json     @default("{}") // blockId, blockType, blockPreview, pollOptions, taskDone, mentions, pinnedAt
  createdAt DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt])
  @@index([userId])
}

model MeetingSession {
  id                   String   @id @default(cuid())
  pageId               String
  workspaceId          String
  createdBy            String
  title                String?
  status               String   @default("active") // "active" | "completed" | "failed"
  mode                 String   @default("single_recorder") // "single_recorder" | "multi_participant"
  storeAudio           Boolean  @default(false)
  audioStoragePath     String?
  lastChunkIndex       Int      @default(-1)
  lastProcessedAt      DateTime?
  lastNotesChunkIndex  Int      @default(-1)
  lastNotesGeneratedAt DateTime?
  lastError            String?
  lastErrorAt          DateTime?
  startedAt            DateTime @default(now())
  endedAt              DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  page       Page              @relation(fields: [pageId], references: [id], onDelete: Cascade)
  workspace  Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chunkReceipts MeetingChunkReceipt[]
  participants MeetingParticipant[]
  speakers   MeetingSpeaker[]
  utterances MeetingUtterance[]
  snapshots  MeetingSnapshot[]

  @@index([pageId, startedAt])
  @@index([workspaceId, status])
}

model MeetingSpeaker {
  id          String   @id @default(cuid())
  sessionId    String
  label        String
  displayName  String?
  source       String   @default("diarization") // "diarization" | "manual" | "participant"
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  session    MeetingSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  utterances MeetingUtterance[]

  @@unique([sessionId, label])
  @@index([sessionId, sortOrder])
}

model MeetingChunkReceipt {
  id               String   @id @default(cuid())
  sessionId        String
  sourceKey        String
  chunkIndex       Int
  chunkStartedAtMs Int
  chunkEndedAtMs   Int
  status           String   @default("processing") // "processing" | "processed" | "failed"
  error            String?
  processedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  session MeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, sourceKey, chunkIndex])
  @@index([sessionId, createdAt])
  @@index([sessionId, sourceKey, chunkIndex])
}

model MeetingParticipant {
  id          String   @id @default(cuid())
  sessionId   String
  userId      String
  displayName String
  status      String   @default("active") // "active" | "inactive"
  joinedAt    DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  leftAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session MeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId, status, joinedAt])
}

model MeetingUtterance {
  id           String   @id @default(cuid())
  sessionId     String
  speakerId     String?
  speakerLabel  String
  text          String
  startMs       Int
  endMs         Int
  chunkIndex    Int
  rawJson       Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  session MeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  speaker MeetingSpeaker? @relation(fields: [speakerId], references: [id], onDelete: SetNull)

  @@index([sessionId, chunkIndex])
  @@index([sessionId, startMs])
}

model MeetingSnapshot {
  id          String   @id @default(cuid())
  sessionId    String
  summary      String   @default("")
  discussion   Json     @default("[]")
  decisions    Json     @default("[]")
  actionItems  Json     @default("[]")
  rawJson      Json     @default("{}")
  createdAt    DateTime @default(now())

  session MeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model WorkspaceChannel {
  id          String   @id @default(cuid())
  workspaceId String
  teamspaceId String?
  createdBy   String
  name        String
  slug        String
  description String?
  icon        String?
  type        String   @default("text") // "text" | "voice"
  topic       String?
  position    Int      @default(0)
  isDefault   Boolean  @default(false)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace      Workspace                     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  teamspace      Teamspace?                    @relation(fields: [teamspaceId], references: [id], onDelete: SetNull)
  messages       WorkspaceChannelMessage[]
  voicePresences WorkspaceChannelVoicePresence[]
  browserSession WorkspaceChannelBrowserSession?
  readStates     WorkspaceChannelReadState[]
  auditLogs      WorkspaceChannelAuditLog[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, teamspaceId, type, position])
}

model WorkspaceChannelMessage {
  id        String    @id @default(cuid())
  channelId String
  userId    String
  content   String
  type      String    @default("text")
  metadata  Json      @default("{}")
  editedAt  DateTime?
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())

  channel WorkspaceChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
  @@index([userId])
}

model WorkspaceChannelVoicePresence {
  id          String   @id @default(cuid())
  channelId   String
  userId      String
  displayName String
  status      String   @default("active") // "active" | "inactive"
  joinedAt    DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  leftAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  channel WorkspaceChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([channelId, status, joinedAt])
}

model WorkspaceChannelReadState {
  id                String   @id @default(cuid())
  channelId         String
  userId            String
  lastReadMessageId String?
  lastReadAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  channel WorkspaceChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId, lastReadAt])
}

model WorkspaceChannelAuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  channelId   String
  userId      String?
  action      String
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel   WorkspaceChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([channelId, createdAt])
  @@index([userId, createdAt])
}

model WorkspaceChannelBrowserSession {
  id                        String   @id @default(cuid())
  channelId                 String   @unique
  ownerUserId               String
  controllerUserId          String
  requestedControllerUserId String?
  activeUrl                 String?
  activeTitle               String?
  activeDomain              String?
  lastNavigatedAt           DateTime @default(now())
  lastControlRequestedAt    DateTime?
  lastControlGrantedAt      DateTime?
  metadata                  Json     @default("{}")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  channel WorkspaceChannel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  tabs    WorkspaceChannelBrowserTab[]

  @@index([controllerUserId])
}

model WorkspaceChannelBrowserTab {
  id              String   @id @default(cuid())
  sessionId       String
  createdByUserId String
  title           String
  url             String
  domain          String?
  position        Int      @default(0)
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  session WorkspaceChannelBrowserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, position])
}

model Template {
  id            String  @id @default(cuid())
  workspaceId   String?
  creatorId     String?
  name          String
  nameKo        String?
  description   String?
  descriptionKo String?
  icon          String?
  coverImage    String?
  category      String  @default("custom")
  locale        String  @default("ko")
  blocks        Json    @default("[]")
  isPublic      Boolean @default(true)
  isDefault     Boolean @default(false)

  workspace  Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator    User?      @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  usageCount Int        @default(0)
  tags       String[]   @default([])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([workspaceId])
  @@index([creatorId])
  @@index([category])
  @@index([isDefault])
  @@index([usageCount])
}

model Webhook {
  id             String    @id @default(cuid())
  workspaceId    String
  name           String
  description    String?
  type           String // "incoming" | "outgoing"
  url            String? // outgoing: target URL; incoming: generated path
  secret         String // HMAC signing secret
  events         String[]  @default([]) // outgoing: subscribed events
  headers        Json? // outgoing: custom headers
  isEnabled      Boolean   @default(true)
  lastDelivered  DateTime?
  totalDelivered Int       @default(0)
  failureCount   Int       @default(0)
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workspace  Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([workspaceId])
  @@index([type])
  @@index([createdBy])
}

model WebhookDelivery {
  id             String   @id @default(cuid())
  webhookId      String
  event          String
  payload        Json
  responseStatus Int?
  responseBody   String?
  durationMs     Int?
  attempt        Int      @default(1)
  status         String // "success" | "failed" | "pending"
  error          String?
  deliveredAt    DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([deliveredAt])
}

enum IntegrationService {
  SLACK
  GITHUB
  GOOGLE_CALENDAR
  EMAIL
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
  EXPIRED
  PENDING
  CONNECTED
  DISCONNECTED
}

model Integration {
  id            String             @id @default(cuid())
  workspaceId   String
  service       IntegrationService
  status        IntegrationStatus  @default(PENDING)
  accessToken   String? // encrypted OAuth access token
  refreshToken  String? // encrypted OAuth refresh token
  tokenExpiry   DateTime?
  externalId    String? // external account/team ID
  externalName  String? // display name (e.g. Slack workspace name)
  config        Json               @default("{}") // per-service config (channels, repos, calendars)
  webhookSecret String? // secret for verifying inbound webhooks
  connectedBy   String
  connectedAt   DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User      @relation("IntegrationCreator", fields: [connectedBy], references: [id], onDelete: Cascade)

  @@unique([workspaceId, service])
  @@index([workspaceId])
  @@index([service, status])
}

model CustomRole {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  permissions Json     @default("[]")
  isBuiltIn   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   WorkspaceMember[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}
